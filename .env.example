# ============================================================
# Mindset — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ============================================================

# ---- Database (Neon Postgres) ----
DATABASE_URL=
DIRECT_URL=

# ---- Auth (NextAuth) ----
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Razorpay ----
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Email (Resend) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Cloudinary (image hosting) ----
CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Shiprocket (physical product fulfillment) ----
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_PICKUP_LOCATION=
SHIPROCKET_PICKUP_PINCODE=
SHIPROCKET_WEBHOOK_TOKEN=

# ---- Google Calendar (session booking) ----
# Base64-encoded service account JSON
GOOGLE_CALENDAR_CREDENTIALS=

# ---- AI (OpenRouter) ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ---- Security (Arcjet rate limiting) ----
ARCJET_KEY=

# ---- Cron / admin ----
CRON_SECRET=
ADMIN_SETUP_SECRET=

# ---- Contact form → Google Sheet ----
# Deploy a Google Apps Script Web App that appends rows; paste its /exec URL here.
# Without this, contact form submissions are discarded (a warning is logged).
GOOGLE_APPS_SCRIPT_CONTACT_URL=
# Shared secret sent in the POST body to the Apps Script (optional but recommended).
# Match this against the SHARED_SECRET in your Apps Script doPost handler.
GOOGLE_APPS_SCRIPT_SECRET=
