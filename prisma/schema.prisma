datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  password      String?
  role          Role      @default(USER)
  address       String?
  emailVerified DateTime?
  image              String?
  dateOfBirth        DateTime?  @map("date_of_birth")
  preferredLanguage  String?    @map("preferred_language")
  emergencyContact   String?    @map("emergency_contact")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")
  // Set when the user requests account deletion. Triggers the 30-day
  // grace window — a successful login any time before scheduledFor
  // clears this field and writes an AccountDeletion cancellation row.
  deletionRequestedAt DateTime? @map("deletion_requested_at")
  createdAt          DateTime   @default(now())
  updatedAt     DateTime  @updatedAt

  doctor      Doctor?
  sessions    Session[]
  assignments Assignment[]
  payments    Payment[]
  orders      Order[]
  accounts    Account[]
  cartItems              CartItem[]
  addresses              Address[]
  passwordResetTokens    PasswordResetToken[]
  workshopRegistrations  WorkshopRegistration[]
  notifications          Notification[]
  journalEntries         JournalEntry[]
  assignmentResponses    AssignmentResponse[]
  moodCheckIns           MoodCheckIn[]
  engagementEvents       EngagementEvent[]
  authEvents             AuthEvent[]
  emailVerificationTokens EmailVerificationToken[]
  studyMaterialAccesses   StudyMaterialAccess[]
  ngoRegistrations       NgoJoinRequest[]
  sessionFollowups        SessionFollowup[]
}

enum Role {
  USER
  DOCTOR
  ADMIN
}

enum PresenterTier {
  PROFESSIONAL
  ASSOCIATE
}

enum WorkshopType {
  WORKSHOP
  CIRCLE
}

enum WorkshopStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Doctor {
  id             String     @id @default(cuid())
  userId         String     @unique
  slug           String     @unique
  photo          String?
  designation    String
  type           DoctorType
  specialization String
  qualification  String
  experience     Int
  bio            String     @db.Text
  sessionPrice   Decimal    @db.Decimal(10, 2)
  isActive       Boolean    @default(true)
  panNumber      String?    @map("pan_number")
  upiId          String?    @map("upi_id")
  payoutFullName String?    @map("payout_full_name")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    Session[]
  assignments Assignment[]
  slots       AvailableSlot[]
  earnings    DoctorEarning[]
  leaves      DoctorLeave[]
  payouts     Payout[]
}

model DoctorLeave {
  id        String   @id @default(cuid())
  doctorId  String   @map("doctor_id")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt       @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, startDate, endDate])
  @@map("doctor_leaves")
}

enum DoctorType {
  COUNSELOR
  PSYCHOLOGIST
}

model AvailableSlot {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Session {
  id              String        @id @default(cuid())
  userId          String
  doctorId        String
  date            DateTime
  meetLink        String?
  calendarEventId String?
  status          SessionStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?       @db.Text
  userNotes       String?       @db.Text @map("user_notes")
  reminderSent    Boolean       @default(false)
  followupSent    Boolean       @default(false)
  // Cancellation audit (set when status flips to CANCELLED). updatedAt
  // also mutates on later edits, so these explicit fields preserve the
  // original cancellation event for refund + audit queries.
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user     User             @relation(fields: [userId], references: [id])
  doctor   Doctor           @relation(fields: [doctorId], references: [id])
  payment  Payment?
  earning  DoctorEarning?
  followup SessionFollowup?
}

enum SessionStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model Assignment {
  id            String           @id @default(cuid())
  doctorId      String
  userId        String
  type          AssignmentType   @default(CUSTOM)
  title         String
  description   String?          @db.Text
  instructions  String           @default("") @db.Text
  fileUrl       String?
  submissionUrl String?
  status        AssignmentStatus @default(PENDING)
  reviewNote    String?          @db.Text
  dueDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  doctor    Doctor               @relation(fields: [doctorId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])
  responses AssignmentResponse[]

  @@index([userId, status])
  @@index([doctorId])
}

enum AssignmentType {
  JOURNAL_PROMPT
  READING
  WORKSHEET
  BREATHING
  CUSTOM
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  COMPLETED
  SKIPPED
  REVIEWED
}

model Presenter {
  id           String         @id @default(cuid())
  name         String
  title        String
  bio          String?        @db.Text
  linkedinUrl  String?        @map("linkedin_url")
  tier         PresenterTier
  upi          String?
  pan          String?
  bankAccount  String?        @map("bank_account")
  ifsc         String?
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt      @map("updated_at")

  workshops    Workshop[]

  @@map("presenters")
}

model Workshop {
  id                String   @id @default(cuid())
  title             String
  subtitle          String?
  description       String   @db.Text
  coverImageUrl     String?  @map("image")
  instructorName    String?
  startsAt          DateTime @map("date")
  durationMin       Int      @default(60)
  priceCents        Int      @default(0)
  capacity          Int?
  whatsappGroupUrl  String?  @map("whatsapp_group_url")
  published         Boolean  @default(false) @map("isPublished")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  type              WorkshopType   @default(WORKSHOP)
  status            WorkshopStatus @default(SCHEDULED)
  presenterId       String?        @map("presenter_id")
  meetLink          String?        @map("meet_link")
  minCapacity       Int            @default(5) @map("min_capacity")
  presenterSplitPct Int            @default(70) @map("presenter_split_pct")
  cancelledAt       DateTime?      @map("cancelled_at")
  cancelReason      String?        @map("cancel_reason")

  presenter     Presenter?             @relation(fields: [presenterId], references: [id], onDelete: Restrict)
  registrations WorkshopRegistration[]
  payments      Payment[]

  @@index([presenterId])
  @@index([startsAt, status])
}

model WorkshopRegistration {
  userId       String
  workshopId   String
  registeredAt DateTime  @default(now())

  paymentId    String?   @unique @map("payment_id")
  refundedAt   DateTime? @map("refunded_at")
  attendedAt   DateTime? @map("attended_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id])

  @@id([userId, workshopId])
  @@index([workshopId, refundedAt])
}

model NgoVisit {
  id          String   @id @default(cuid())
  ngoName     String
  location    String
  description String   @db.Text
  photos      String[]
  visitDate   DateTime
  capacity    Int?     // null = unlimited
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  registrations NgoJoinRequest[]
}

model NgoJoinRequest {
  id         String        @id @default(cuid())
  name       String
  email      String
  phone      String
  age        Int?
  interest   String        @db.Text
  status     NgoJoinStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  // @default(now()) backfills existing rows so `db push` can add this
  // NOT NULL column without a non-empty-table prompt; @updatedAt keeps
  // it fresh on every later mutation.
  updatedAt  DateTime      @default(now()) @updatedAt

  userId     String?
  ngoVisitId String?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  ngoVisit NgoVisit? @relation(fields: [ngoVisitId], references: [id], onDelete: SetNull)

  @@unique([userId, ngoVisitId])
}

enum NgoJoinStatus {
  PENDING
  CONTACTED
  CONFIRMED
  ATTENDED
  NO_SHOW
  CANCELLED
}

model WhatsappLink {
  id        String   @id @default(cuid())
  link      String
  label     String   @default("NGO Drive")
  updatedAt DateTime @updatedAt
  updatedBy String
}

model StudyMaterial {
  id          String            @id @default(cuid())
  title       String
  type        StudyMaterialType
  price       Decimal?          @db.Decimal(10, 2)
  fileUrl     String
  coverImage  String?
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  accesses StudyMaterialAccess[]
}

model StudyMaterialAccess {
  id           String   @id @default(cuid())
  userId       String
  materialId   String
  lastOpenedAt DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  material StudyMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@index([userId, lastOpenedAt])
}

enum StudyMaterialType {
  FREE
  PAID
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  image       String?
  sku         String?
  weight      Float?   @default(0.5)
  isActive    Boolean  @default(true)
  isDigital   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                   String         @id @default(cuid())
  orderNumber          String?        @unique @map("order_number")
  userId               String
  totalAmount          Decimal        @db.Decimal(10, 2)
  paymentStatus        PaymentStatus  @default(PENDING)
  shippingStatus       ShippingStatus @default(PENDING)
  shiprocketOrderId    Int?
  shiprocketShipmentId Int?
  awbCode              String?
  courierName          String?
  trackingUrl          String?
  deliveryCharge       Decimal        @default(0) @db.Decimal(10, 2)
  selectedCourierId    Int?
  selectedCourierName  String?
  shippingAddress      Json
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  payment    Payment?
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id                  String        @id @default(cuid())
  userId              String
  amount              Decimal       @db.Decimal(10, 2)
  type                PaymentType
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  status              PaymentStatus @default(PENDING)
  sessionId           String?       @unique
  orderId             String?       @unique
  studyMaterialId     String?
  // For type=WORKSHOP, links the pending Payment to its target Workshop
  // BEFORE a WorkshopRegistration row exists. Registration is created
  // only after Razorpay captures the payment (webhook).
  workshopId          String?       @map("workshop_id")
  // Refund tracking (separate from .status which is the payment's own
  // lifecycle). Set when cancelSession or future admin/doctor cancel
  // paths fire a Razorpay refund. amount is in paise (matches the
  // Razorpay refund API contract) to avoid Decimal precision games on
  // partial refunds.
  refundId            String?       @map("refund_id")
  refundedAt          DateTime?     @map("refunded_at")
  refundAmount        Int?          @map("refund_amount")
  refundStatus        String?       @map("refund_status")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                 User                  @relation(fields: [userId], references: [id])
  session              Session?              @relation(fields: [sessionId], references: [id])
  order                Order?                @relation(fields: [orderId], references: [id])
  workshop             Workshop?             @relation(fields: [workshopId], references: [id])
  earning              DoctorEarning?
  workshopRegistration WorkshopRegistration?
}

enum PaymentType {
  SESSION
  PRODUCT
  EBOOK
  WORKSHOP
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  label        String
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DoctorEarning {
  id             String        @id @default(cuid())
  doctorId       String
  sessionId      String        @unique
  paymentId      String        @unique
  grossAmount    Decimal       @db.Decimal(10, 2)
  doctorAmount   Decimal       @db.Decimal(10, 2)
  platformAmount Decimal       @db.Decimal(10, 2)
  status         EarningStatus @default(PENDING)
  payoutId       String?       @map("payout_id")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  payout  Payout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([payoutId])
}

enum EarningStatus {
  PENDING
  PAID
}

model Payout {
  id              String        @id @default(cuid())
  doctorId        String        @map("doctor_id")
  amount          Decimal       @db.Decimal(10, 2)
  method          PayoutMethod  @default(UPI)
  transactionRef  String?       @map("transaction_ref")
  note            String?       @db.Text
  paidAt          DateTime      @default(now()) @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  doctor   Doctor          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  earnings DoctorEarning[]

  @@index([doctorId, paidAt(sort: Desc)])
  @@map("payouts")
}

enum PayoutMethod {
  UPI
  BANK_TRANSFER
  OTHER
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  kind      NotificationKind
  title     String
  body      String
  link      String?
  createdAt DateTime           @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

enum NotificationKind {
  SESSION_REMINDER
  SESSION_CANCELLED
  WORKSHOP
  WORKSHOP_REGISTRATION_CONFIRMED
  ORDER
  REVIEW_PROMPT
  REFUND_PROCESSED
  SYSTEM
  ASSIGNMENT_NEW
  ASSIGNMENT_COMPLETED
  // ── doctor-facing kinds ──
  SESSION_BOOKED
  SESSION_CANCELLED_BY_USER
  ASSIGNMENT_SUBMITTED
  EARNING_PAID
}

model JournalEntry {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  title          String?
  body           String    @db.Text
  mood           Int?
  isDraft        Boolean   @default(false) @map("is_draft")
  draftUpdatedAt DateTime? @map("draft_updated_at")
  assignmentId   String?   @map("assignment_id")
  entryDate      DateTime  @default(now()) @map("entry_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt       @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entryDate(sort: Desc)])
  @@index([userId, isDraft])
  @@map("journal_entries")
}

enum EngagementKind {
  MOOD_LOGGED
  SESSION_ATTENDED
  ASSIGNMENT_COMPLETED
  JOURNAL_ENTRY_CREATED
}

model EngagementEvent {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  kind       EngagementKind
  occurredAt DateTime       @default(now()) @map("occurred_at")
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@map("engagement_events")
}

model MoodCheckIn {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  mood          Int      // 1..5
  note          String?  @db.Text
  checkedInDate DateTime @map("checked_in_date") @db.Date
  checkedInAt   DateTime @default(now()) @map("checked_in_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkedInDate])
  @@index([userId, checkedInDate(sort: Desc)])
  @@map("mood_check_ins")
}

// Post-session follow-up row. One per Session (unique sessionId).
// Created by the user via the post-session interstitial:
//   step 1 → postMood + homeworkNote (the user's reflection)
//   step 2 → rebookIntent (did they tap "book next session"?)
// The presence of a SessionFollowup row is the signal that the
// interstitial has been seen; pending-post-session detection uses
// `followup: null` to find sessions still owed an interstitial.
model SessionFollowup {
  id           String    @id @default(cuid())
  sessionId    String    @unique @map("session_id")
  userId       String    @map("user_id")
  postMood     Int?      @map("post_mood")       // 1..5, optional
  homeworkNote String?   @db.Text @map("homework_note") // user reflection, optional
  rebookIntent Boolean?  @map("rebook_intent")   // tapped "book next"?
  completedAt  DateTime  @default(now()) @map("completed_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("session_followups")
}

model AssignmentResponse {
  id           String   @id @default(cuid())
  assignmentId String   @map("assignment_id")
  userId       String   @map("user_id")
  responseText String?  @db.Text @map("response_text")
  metadata     Json?
  completedAt  DateTime @default(now()) @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("assignment_responses")
}

model AuthEvent {
  id        String        @id @default(cuid())
  userId    String?       @map("user_id")
  kind      AuthEventKind
  ip        String?
  userAgent String?       @map("user_agent")
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("auth_events")
}

enum AuthEventKind {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_GOOGLE_SUCCESS
  LOGIN_GOOGLE_BLOCKED
  REGISTER_SUCCESS
  REGISTER_FAILED
  REGISTER_GOOGLE
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  ACCOUNT_LOCKED
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

// Audit log of account deletion events. Intentionally has NO foreign-key
// relation to User — when the deletion job removes the user row, the audit
// trail must survive (DPDP-required record of consent + processing).
// userId is stored as a plain string; userEmail is captured at request time
// so we still have a usable identifier after hard-delete.
model AccountDeletion {
  id            String                @id @default(cuid())
  userId        String                @map("user_id")
  userEmail     String                @map("user_email")
  kind          AccountDeletionKind   @default(REQUESTED)
  reason        String?               @db.Text
  freeText      String?               @db.Text @map("free_text")
  ip            String?
  userAgent     String?               @map("user_agent")
  scheduledFor  DateTime?             @map("scheduled_for")
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([userId])
  @@index([kind, scheduledFor])
  @@map("account_deletions")
}

enum AccountDeletionKind {
  REQUESTED
  CANCELLED
  EXECUTED
}
