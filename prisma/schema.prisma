datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  password      String?
  role          Role      @default(USER)
  address       String?
  emailVerified DateTime?
  image              String?
  dateOfBirth        DateTime?  @map("date_of_birth")
  preferredLanguage  String?    @map("preferred_language")
  emergencyContact   String?    @map("emergency_contact")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")
  createdAt          DateTime   @default(now())
  updatedAt     DateTime  @updatedAt

  doctor      Doctor?
  sessions    Session[]
  assignments Assignment[]
  payments    Payment[]
  orders      Order[]
  accounts    Account[]
  cartItems              CartItem[]
  addresses              Address[]
  passwordResetTokens    PasswordResetToken[]
  workshopRegistrations  WorkshopRegistration[]
  notifications          Notification[]
  journalEntries         JournalEntry[]
  assignmentResponses    AssignmentResponse[]
  moodCheckIns           MoodCheckIn[]
  engagementEvents       EngagementEvent[]
  authEvents             AuthEvent[]
  emailVerificationTokens EmailVerificationToken[]
}

enum Role {
  USER
  DOCTOR
  ADMIN
}

enum PresenterTier {
  PROFESSIONAL
  ASSOCIATE
}

enum WorkshopType {
  WORKSHOP
  CIRCLE
}

enum WorkshopStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Doctor {
  id             String     @id @default(cuid())
  userId         String     @unique
  slug           String     @unique
  photo          String?
  designation    String
  type           DoctorType
  specialization String
  qualification  String
  experience     Int
  bio            String     @db.Text
  sessionPrice   Decimal    @db.Decimal(10, 2)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    Session[]
  assignments Assignment[]
  slots       AvailableSlot[]
  earnings    DoctorEarning[]
}

enum DoctorType {
  COUNSELOR
  PSYCHOLOGIST
}

model AvailableSlot {
  id        String   @id @default(cuid())
  doctorId  String
  date      DateTime
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Session {
  id              String        @id @default(cuid())
  userId          String
  doctorId        String
  date            DateTime
  meetLink        String?
  calendarEventId String?
  status          SessionStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?       @db.Text
  userNotes       String?       @db.Text @map("user_notes")
  reminderSent    Boolean       @default(false)
  followupSent    Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User           @relation(fields: [userId], references: [id])
  doctor  Doctor         @relation(fields: [doctorId], references: [id])
  payment Payment?
  earning DoctorEarning?
}

enum SessionStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model Assignment {
  id            String           @id @default(cuid())
  doctorId      String
  userId        String
  type          AssignmentType   @default(CUSTOM)
  title         String
  description   String?          @db.Text
  instructions  String           @default("") @db.Text
  fileUrl       String?
  submissionUrl String?
  status        AssignmentStatus @default(PENDING)
  reviewNote    String?          @db.Text
  dueDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  doctor    Doctor               @relation(fields: [doctorId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])
  responses AssignmentResponse[]

  @@index([userId, status])
  @@index([doctorId])
}

enum AssignmentType {
  JOURNAL_PROMPT
  READING
  WORKSHEET
  BREATHING
  CUSTOM
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  COMPLETED
  SKIPPED
  REVIEWED
}

model Presenter {
  id           String         @id @default(cuid())
  name         String
  title        String
  bio          String?        @db.Text
  linkedinUrl  String?        @map("linkedin_url")
  tier         PresenterTier
  upi          String?
  pan          String?
  bankAccount  String?        @map("bank_account")
  ifsc         String?
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt      @map("updated_at")

  workshops    Workshop[]

  @@map("presenters")
}

model Workshop {
  id                String   @id @default(cuid())
  title             String
  subtitle          String?
  description       String   @db.Text
  coverImageUrl     String?  @map("image")
  instructorName    String?
  startsAt          DateTime @map("date")
  durationMin       Int      @default(60)
  priceCents        Int      @default(0)
  capacity          Int?
  whatsappGroupUrl  String?  @map("whatsapp_group_url")
  published         Boolean  @default(false) @map("isPublished")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  type              WorkshopType   @default(WORKSHOP)
  status            WorkshopStatus @default(SCHEDULED)
  presenterId       String?        @map("presenter_id")
  meetLink          String?        @map("meet_link")
  minCapacity       Int            @default(5) @map("min_capacity")
  presenterSplitPct Int            @default(70) @map("presenter_split_pct")
  cancelledAt       DateTime?      @map("cancelled_at")
  cancelReason      String?        @map("cancel_reason")

  presenter     Presenter?             @relation(fields: [presenterId], references: [id], onDelete: Restrict)
  registrations WorkshopRegistration[]

  @@index([presenterId])
  @@index([startsAt, status])
}

model WorkshopRegistration {
  userId       String
  workshopId   String
  registeredAt DateTime  @default(now())

  paymentId    String?   @unique @map("payment_id")
  refundedAt   DateTime? @map("refunded_at")
  attendedAt   DateTime? @map("attended_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id])

  @@id([userId, workshopId])
  @@index([workshopId, refundedAt])
}

model NgoVisit {
  id          String   @id @default(cuid())
  ngoName     String
  location    String
  description String   @db.Text
  photos      String[]
  visitDate   DateTime
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model NgoJoinRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  city      String
  age       Int
  interest  String   @db.Text
  createdAt DateTime @default(now())
}

model WhatsappLink {
  id        String   @id @default(cuid())
  link      String
  label     String   @default("NGO Drive")
  updatedAt DateTime @updatedAt
  updatedBy String
}

model StudyMaterial {
  id          String            @id @default(cuid())
  title       String
  type        StudyMaterialType
  price       Decimal?          @db.Decimal(10, 2)
  fileUrl     String
  coverImage  String?
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum StudyMaterialType {
  FREE
  PAID
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  image       String?
  sku         String?
  weight      Float?   @default(0.5)
  isActive    Boolean  @default(true)
  isDigital   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                   String         @id @default(cuid())
  userId               String
  totalAmount          Decimal        @db.Decimal(10, 2)
  paymentStatus        PaymentStatus  @default(PENDING)
  shippingStatus       ShippingStatus @default(PENDING)
  shiprocketOrderId    Int?
  shiprocketShipmentId Int?
  awbCode              String?
  courierName          String?
  trackingUrl          String?
  deliveryCharge       Decimal        @default(0) @db.Decimal(10, 2)
  selectedCourierId    Int?
  selectedCourierName  String?
  shippingAddress      Json
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  payment    Payment?
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id                  String        @id @default(cuid())
  userId              String
  amount              Decimal       @db.Decimal(10, 2)
  type                PaymentType
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  status              PaymentStatus @default(PENDING)
  sessionId           String?       @unique
  orderId             String?       @unique
  studyMaterialId     String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                 User                  @relation(fields: [userId], references: [id])
  session              Session?              @relation(fields: [sessionId], references: [id])
  order                Order?                @relation(fields: [orderId], references: [id])
  earning              DoctorEarning?
  workshopRegistration WorkshopRegistration?
}

enum PaymentType {
  SESSION
  PRODUCT
  EBOOK
  WORKSHOP
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  label        String
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DoctorEarning {
  id             String        @id @default(cuid())
  doctorId       String
  sessionId      String        @unique
  paymentId      String        @unique
  grossAmount    Decimal       @db.Decimal(10, 2)
  doctorAmount   Decimal       @db.Decimal(10, 2)
  platformAmount Decimal       @db.Decimal(10, 2)
  status         EarningStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([doctorId])
}

enum EarningStatus {
  PENDING
  PAID
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  kind      NotificationKind
  title     String
  body      String
  link      String?
  createdAt DateTime           @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

enum NotificationKind {
  SESSION_REMINDER
  WORKSHOP
  ORDER
  REVIEW_PROMPT
  SYSTEM
  ASSIGNMENT_NEW
  ASSIGNMENT_COMPLETED
}

model JournalEntry {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  title          String?
  body           String    @db.Text
  mood           Int?
  isDraft        Boolean   @default(false) @map("is_draft")
  draftUpdatedAt DateTime? @map("draft_updated_at")
  assignmentId   String?   @map("assignment_id")
  entryDate      DateTime  @default(now()) @map("entry_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt       @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entryDate(sort: Desc)])
  @@index([userId, isDraft])
  @@map("journal_entries")
}

enum EngagementKind {
  MOOD_LOGGED
  SESSION_ATTENDED
  ASSIGNMENT_COMPLETED
  JOURNAL_ENTRY_CREATED
}

model EngagementEvent {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  kind       EngagementKind
  occurredAt DateTime       @default(now()) @map("occurred_at")
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@map("engagement_events")
}

model MoodCheckIn {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  mood          Int      // 1..5
  note          String?  @db.Text
  checkedInDate DateTime @map("checked_in_date") @db.Date
  checkedInAt   DateTime @default(now()) @map("checked_in_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkedInDate])
  @@index([userId, checkedInDate(sort: Desc)])
  @@map("mood_check_ins")
}

model AssignmentResponse {
  id           String   @id @default(cuid())
  assignmentId String   @map("assignment_id")
  userId       String   @map("user_id")
  responseText String?  @db.Text @map("response_text")
  metadata     Json?
  completedAt  DateTime @default(now()) @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("assignment_responses")
}

model AuthEvent {
  id        String        @id @default(cuid())
  userId    String?       @map("user_id")
  kind      AuthEventKind
  ip        String?
  userAgent String?       @map("user_agent")
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("auth_events")
}

enum AuthEventKind {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_GOOGLE_SUCCESS
  LOGIN_GOOGLE_BLOCKED
  REGISTER_SUCCESS
  REGISTER_FAILED
  REGISTER_GOOGLE
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  ACCOUNT_LOCKED
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}
